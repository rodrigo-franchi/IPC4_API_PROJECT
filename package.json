{
  "name": "ipc4-api-project",
  "version": "1.0.0",
  "description": "API CRUD para cadastro de clientes - Projeto acadêmico IPC4",
  "main": "src/index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write src/**/*.js",
    "format:check": "prettier --check src/**/*.js"
  },
  "keywords": [
    "api",
    "crud",
    "clientes",
    "mongodb",
    "express",
    "tdd",
    "bdd"
  ],
  "author": "Rodrigo - Projeto Acadêmico IPC4",
  "license": "ISC",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^9.6.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "eslint": "^10.2.1",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.1.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.0.3",
    "supertest": "^6.3.3"
  }
}
